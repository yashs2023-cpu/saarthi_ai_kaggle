# ═══════════════════════════════════════════════
# SAARTHI AI — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── REQUIRED: Gemini AI API Key ─────────────────
# Get yours FREE at: https://aistudio.google.com/app/apikey
# Without this key, the app falls back to offline responses
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── OPTIONAL: Backend API URL ───────────────────
# Only needed if you run the Express backend locally
# Leave as-is if you only want the frontend (it works standalone)
VITE_API_URL=http://localhost:5000/api

# ── App Info ────────────────────────────────────
VITE_APP_NAME=Saarthi AI
VITE_APP_VERSION=2.0.0

# ═══════════════════════════════════════════════
# QUICK START (Frontend only — no backend needed)
# ═══════════════════════════════════════════════
# 1. npm install
# 2. cp .env.example .env
# 3. Add your Gemini API key to .env
# 4. npm run dev
# 5. Open http://localhost:3000
# 6. Login with: demo@saarthi.ai / Demo@1234
